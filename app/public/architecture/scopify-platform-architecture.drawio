        </mxCell>

        <!-- ===== CLUSTER NODES ===== -->
        <mxCell id="k_cluster" value="KUBERNETES CLUSTER — 1 Control-Plane + 2 Workers (private subnets · Calico overlay)" style="rounded=0;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontSize=14;fontStyle=1;fillColor=#EFF6FF;strokeColor=#2563EB;strokeWidth=2;" vertex="1" parent="k1">
          <mxGeometry x="60" y="340" width="2080" height="980" as="geometry"/>
        </mxCell>

        <!-- Control plane node -->
        <mxCell id="k_cp" value="NODE 1 — CONTROL PLANE&#xa;EC2 Master · e.g. ip-10-20-56-220 · Private IP in 10.20.32.0/20&#xa;Roles: control-plane · kube-apiserver :6443 · etcd · scheduler · controller-manager · CoreDNS · kube-proxy · Calico" style="rounded=0;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;align=left;spacingLeft=8;spacingTop=4;fontSize=12;fontStyle=1;fillColor=#F8FAFC;strokeColor=#64748B;strokeWidth=2;" vertex="1" parent="k_cluster">
          <mxGeometry x="20" y="50" width="660" height="400" as="geometry"/>
        </mxCell>
        <mxCell id="k_cp_api" value="kube-apiserver&#xa;:6443 (cluster SG)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=10;" vertex="1" parent="k_cp">
          <mxGeometry x="20" y="70" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="k_cp_etcd" value="etcd&#xa;cluster state" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=10;" vertex="1" parent="k_cp">
          <mxGeometry x="185" y="70" width="130" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="k_cp_sched" value="scheduler +&#xa;controller-manager" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=10;" vertex="1" parent="k_cp">
          <mxGeometry x="330" y="70" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="k_cp_dns" value="CoreDNS&#xa;Service discovery" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=10;" vertex="1" parent="k_cp">
          <mxGeometry x="500" y="70" width="130" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="k_cp_proxy" value="kube-proxy&#xa;NodePort iptables/IPVS&#xa;opens :32208 / :30201 on ALL nodes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="k_cp">
          <mxGeometry x="20" y="140" width="300" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="k_cp_calico" value="Calico node&#xa;Pod CIDR slice on this node" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=10;" vertex="1" parent="k_cp">
          <mxGeometry x="340" y="140" width="280" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="k_cp_note" value="Workloads usually prefer workers, but control-plane may schedule system pods.&#xa;kubectl / Jenkins kubeconfig talks to this apiserver." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#94A3B8;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="k_cp">
          <mxGeometry x="20" y="220" width="600" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="k_cp_np" value="NodePort listener :32208&#xa;(forwards to Ingress Controller endpoints)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;fontSize=10;fontStyle=1;" vertex="1" parent="k_cp">
          <mxGeometry x="20" y="295" width="600" height="45" as="geometry"/>
        </mxCell>

        <!-- Worker 1 -->
        <mxCell id="k_w1" value="NODE 2 — WORKER-1&#xa;e.g. ip-10-20-54-98 · kubelet + containerd + Calico + kube-proxy&#xa;Often hosts: ingress-nginx-controller pod (schedulable worker)" style="rounded=0;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;align=left;spacingLeft=8;spacingTop=4;fontSize=12;fontStyle=1;fillColor=#ECFDF5;strokeColor=#059669;strokeWidth=2;" vertex="1" parent="k_cluster">
          <mxGeometry x="700" y="50" width="680" height="400" as="geometry"/>
        </mxCell>
        <mxCell id="k_w1_np" value="NodePort :32208 / :30201 (kube-proxy)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;fontSize=10;fontStyle=1;" vertex="1" parent="k_w1">
          <mxGeometry x="20" y="70" width="640" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="k_ing_ctrl" value="POD: ingress-nginx-controller&#xa;ns: ingress-nginx&#xa;image: ingress-nginx/controller&#xa;Listens :80/:443 inside pod&#xa;Reads Ingress objects cluster-wide&#xa;Matches Host: dev.ashmit.xyz → backend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0E7FF;strokeColor=#4F46E5;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=4;fontStyle=1;" vertex="1" parent="k_w1">
          <mxGeometry x="20" y="120" width="300" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="k_ing_svc" value="SVC: ingress-nginx-controller&#xa;TYPE: LoadBalancer&#xa;CLUSTER-IP: e.g. 10.104.x.x&#xa;NodePort map:&#xa;  80 → 32208&#xa;  443 → 30201" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C7D2FE;strokeColor=#4338CA;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=4;" vertex="1" parent="k_w1">
          <mxGeometry x="340" y="120" width="300" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="k_w1_pod_opt" value="May also schedule hello-app pods&#xa;(scheduler chooses by resources / rules)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBF7D0;strokeColor=#15803D;fontSize=10;" vertex="1" parent="k_w1">
          <mxGeometry x="20" y="260" width="640" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="k_w1_calico" value="Calico · Pod IPs 10.244.x.x/32 on this node" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=10;" vertex="1" parent="k_w1">
          <mxGeometry x="20" y="320" width="640" height="40" as="geometry"/>
        </mxCell>

        <!-- Worker 2 -->
        <mxCell id="k_w2" value="NODE 3 — WORKER-2&#xa;e.g. ip-10-20-32-64 · kubelet + containerd + Calico + kube-proxy&#xa;Often hosts: hello-app ReplicaSet pods" style="rounded=0;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;align=left;spacingLeft=8;spacingTop=4;fontSize=12;fontStyle=1;fillColor=#ECFDF5;strokeColor=#059669;strokeWidth=2;" vertex="1" parent="k_cluster">
          <mxGeometry x="1400" y="50" width="660" height="400" as="geometry"/>
        </mxCell>
        <mxCell id="k_w2_np" value="NodePort :32208 / :30201 (kube-proxy)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;fontSize=10;fontStyle=1;" vertex="1" parent="k_w2">
          <mxGeometry x="20" y="70" width="620" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="k_pod_a" value="POD hello-app-xxxx-a&#xa;label: app=hello-app&#xa;containerPort: 3000&#xa;image: ghcr.io/...:&lt;sha&gt;&#xa;imagePullSecrets: ghcr-secret&#xa;Nginx serves React SPA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBF7D0;strokeColor=#15803D;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=4;fontStyle=1;" vertex="1" parent="k_w2">
          <mxGeometry x="20" y="120" width="290" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="k_pod_b" value="POD hello-app-xxxx-b&#xa;label: app=hello-app&#xa;containerPort: 3000&#xa;image: ghcr.io/...:&lt;sha&gt;&#xa;replicas spread for HA&#xa;(Deployment replicas: 2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBF7D0;strokeColor=#15803D;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=4;fontStyle=1;" vertex="1" parent="k_w2">
          <mxGeometry x="330" y="120" width="290" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="k_w2_note" value="Pods get Calico IPs (e.g. 10.244.193.195).&#xa;Service Endpoints track Ready pod IPs:3000." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="k_w2">
          <mxGeometry x="20" y="260" width="600" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="k_w2_pull" value="Pull from GHCR using ghcr-secret (namespace)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#7C3AED;fontSize=10;" vertex="1" parent="k_w2">
          <mxGeometry x="20" y="325" width="600" height="35" as="geometry"/>
        </mxCell>

        <!-- Control plane objects / API resources -->
        <mxCell id="k_objects" value="CLUSTER API OBJECTS (desired state in etcd — applied by Jenkins / kubectl)" style="rounded=0;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;align=left;spacingLeft=8;spacingTop=4;fontSize=13;fontStyle=1;fillColor=#FFF7ED;strokeColor=#EA580C;strokeWidth=2;" vertex="1" parent="k_cluster">
          <mxGeometry x="20" y="470" width="2040" height="280" as="geometry"/>
        </mxCell>

        <mxCell id="k_obj_ns" value="Namespace&#xa;k8s-demo-namespace" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#DB2777;fontSize=11;fontStyle=1;" vertex="1" parent="k_objects">
          <mxGeometry x="20" y="45" width="180" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="k_obj_ing" value="Ingress: hello-ingress&#xa;class: nginx&#xa;host: dev.ashmit.xyz&#xa;path: / (Prefix)&#xa;→ hello-service:80" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0E7FF;strokeColor=#4F46E5;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=4;fontStyle=1;" vertex="1" parent="k_objects">
          <mxGeometry x="220" y="40" width="220" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="k_obj_svc" value="Service: hello-service&#xa;TYPE: ClusterIP&#xa;selector: app=hello-app&#xa;port: 80&#xa;targetPort: 3000&#xa;(stable VIP inside cluster)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFFAFE;strokeColor=#0891B2;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=4;fontStyle=1;" vertex="1" parent="k_objects">
          <mxGeometry x="460" y="40" width="230" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="k_obj_dep" value="Deployment: hello-app&#xa;replicas: 2&#xa;strategy: RollingUpdate&#xa;container: hello-app&#xa;port: 3000&#xa;imagePullPolicy: Always&#xa;Jenkins: kubectl set image" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBF7D0;strokeColor=#15803D;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=4;fontStyle=1;" vertex="1" parent="k_objects">
          <mxGeometry x="710" y="40" width="240" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="k_obj_rs" value="ReplicaSet&#xa;hello-app-&lt;hash&gt;&#xa;owns Pods&#xa;labels: app=hello-app&#xa;pod-template-hash" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#86EFAC;strokeColor=#166534;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=4;" vertex="1" parent="k_objects">
          <mxGeometry x="970" y="40" width="200" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="k_obj_ep" value="Endpoints / EndpointSlice&#xa;PodIP:3000 + PodIP:3000&#xa;updated as pods Ready" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5F3FC;strokeColor=#0E7490;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=4;" vertex="1" parent="k_objects">
          <mxGeometry x="1190" y="40" width="230" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="k_obj_sec" value="Secret: ghcr-secret&#xa;type: docker-registry&#xa;used by imagePullSecrets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#7C3AED;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=4;" vertex="1" parent="k_objects">
          <mxGeometry x="1440" y="40" width="220" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="k_obj_ingc" value="IngressClass: nginx&#xa;controller:&#xa;k8s.io/ingress-nginx" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C7D2FE;strokeColor=#4338CA;fontSize=10;align=left;spacingLeft=6;verticalAlign=top;spacingTop=4;" vertex="1" parent="k_objects">
          <mxGeometry x="1680" y="40" width="180" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="k_obj_chain" value="Object chain: Namespace → Deployment → ReplicaSet → Pods&#xa;Ingress → (Host/path match) → Service → Endpoints → Pod:3000&#xa;Ingress-Nginx Service (NodePort) → Controller Pod → above Ingress rules" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;fontSize=11;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="k_objects">
          <mxGeometry x="20" y="185" width="2000" height="70" as="geometry"/>
        </mxCell>

        <!-- CI/CD strip -->
        <mxCell id="k_cicd" value="CI/CD → CLUSTER&#xa;1. Jenkins builds multi-stage image (Vite React → nginx:alpine listen :3000)&#xa;2. Push ghcr.io/ashmit-gupta/k8-test-project:&lt;git-sha&gt; (+ :latest)&#xa;3. kubectl apply -f k8s/ (ns, svc, ingress, deploy)&#xa;4. kubectl set image deployment/hello-app hello-app=…:&lt;sha&gt; -n k8s-demo-namespace&#xa;5. Rollout creates new pods; Service endpoints update; Ingress keeps same Host" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="k_cluster">
          <mxGeometry x="20" y="770" width="1000" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="k_security" value="SECURITY / NETWORK NOTES&#xa;• Cluster SG: allow NodePort 30000–32767 from Nginx SG (or VPC)&#xa;• Only edge Nginx has public EIP — nodes stay private&#xa;• Host header must equal Ingress host (dev.ashmit.xyz)&#xa;• ghcr-secret never committed to Git — cluster Secret only&#xa;• Cloudflare 526 if origin cert name ≠ host (use matching cert / Full SSL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="k_cluster">
          <mxGeometry x="1040" y="770" width="1000" height="130" as="geometry"/>
        </mxCell>

        <!-- Legend -->
        <mxCell id="k_legend" value="Legend: Amber = edge / NodePort · Blue = Nginx / Jenkins · Indigo = Ingress controller &amp; Ingress · Cyan = ClusterIP Service / Endpoints · Green = Worker nodes &amp; app Pods · Purple = GHCR / pull secrets · Pink = Namespace. Open this tab in diagrams.net: “Kubernetes Workload Architecture”." style="rounded=1;whiteSpace=wrap;html=1;align=left;spacing=8;fillColor=#F1F5F9;strokeColor=#64748B;fontSize=11;" vertex="1" parent="k1">
          <mxGeometry x="60" y="1340" width="2080" height="40" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="ke1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="k1" source="k_user" target="k_cf"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ke2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="k1" source="k_cf" target="k_nginx"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ke3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#EA580C;" edge="1" parent="k1" source="k_nginx" target="k_nodeport_note"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ke4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#EA580C;dashed=1;" edge="1" parent="k1" source="k_nodeport_note" target="k_w1_np"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ke5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#4F46E5;" edge="1" parent="k1" source="k_w1_np" target="k_ing_svc"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ke6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#4F46E5;" edge="1" parent="k1" source="k_ing_svc" target="k_ing_ctrl"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ke7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#4F46E5;" edge="1" parent="k1" source="k_ing_ctrl" target="k_obj_ing"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ke8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#0891B2;" edge="1" parent="k1" source="k_obj_ing" target="k_obj_svc"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ke9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#0891B2;" edge="1" parent="k1" source="k_obj_svc" target="k_obj_ep"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ke10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#15803D;" edge="1" parent="k1" source="k_obj_ep" target="k_pod_a"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ke11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=1.5;strokeColor=#15803D;" edge="1" parent="k1" source="k_obj_ep" target="k_pod_b"><mxGeometry relative="1" as="geometry"/></mxCell>
