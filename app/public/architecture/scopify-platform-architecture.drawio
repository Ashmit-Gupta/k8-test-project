  <diagram id="k8s-workload-arch" name="Kubernetes Workload Architecture">
    <mxGraphModel dx="2200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="k0"/>
        <mxCell id="k1" parent="k0"/>

        <mxCell id="k_title" value="KUBERNETES WORKLOAD ARCHITECTURE — k8-test-project / Portfolio&#xa;Cluster: kubeadm · Calico 10.244.0.0/16 · Ingress-Nginx (NodePort 80→32208, 443→30201) · Namespace: k8s-demo-namespace · Host: dev.ashmit.xyz" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontColor=#111827;" vertex="1" parent="k1">
          <mxGeometry x="40" y="10" width="2100" height="55" as="geometry"/>
        </mxCell>

        <!-- ===== EXTERNAL ===== -->
        <mxCell id="k_user" value="Recruiter / Browser&#xa;https://dev.ashmit.xyz" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2E8F0;strokeColor=#475569;fontStyle=1;fontSize=12;" vertex="1" parent="k1">
          <mxGeometry x="60" y="80" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="k_cf" value="Cloudflare DNS&#xa;dev.ashmit.xyz → Nginx EIP&#xa;(SSL / proxy as configured)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=11;" vertex="1" parent="k1">
          <mxGeometry x="320" y="75" width="240" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="k_jenkins_ext" value="Jenkins CI/CD&#xa;build → push GHCR&#xa;kubectl apply + set image&#xa;(git SHA tag)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=11;" vertex="1" parent="k1">
          <mxGeometry x="1680" y="75" width="240" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="k_ghcr" value="GHCR&#xa;ghcr.io/ashmit-gupta/&#xa;k8-test-project:&lt;sha&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#7C3AED;fontSize=11;" vertex="1" parent="k1">
          <mxGeometry x="1960" y="75" width="180" height="70" as="geometry"/>
        </mxCell>

        <!-- ===== EDGE ===== -->
        <mxCell id="k_edge" value="EDGE — Public subnet (Nginx EC2 · EIP e.g. 52.66.11.36)" style="rounded=0;whiteSpace=wrap;html=1;container=1;collapsible=0;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontSize=13;fontStyle=1;fillColor=#FEF9C3;strokeColor=#D97706;strokeWidth=2;" vertex="1" parent="k1">
          <mxGeometry x="60" y="170" width="2080" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="k_nginx" value="scopify-nginx (Docker nginx:1.27-alpine)&#xa;server_name: dev.ashmit.xyz (TLS)&#xa;proxy_pass → http://&lt;K8s-node&gt;:32208&#xa;Headers: Host, X-Real-IP, X-Forwarded-For/Proto&#xa;Prefer node hosting Ingress controller (e.g. 10.20.54.98)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;fontStyle=1;" vertex="1" parent="k_edge">
          <mxGeometry x="20" y="40" width="520" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="k_nodeport_note" value="NodePort entry into cluster&#xa;Service: ingress-nginx-controller&#xa;TYPE: LoadBalancer (EXTERNAL-IP pending)&#xa;PORTS: 80:32208/TCP · 443:30201/TCP&#xa;Any Schedulable node can receive NodePort&#xa;(SG must allow 32208 from Nginx SG)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="k_edge">
          <mxGeometry x="560" y="30" width="420" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="k_flow_legend" value="Traffic path&#xa;Browser → Cloudflare → Edge Nginx :443&#xa;→ NodePort :32208 → Ingress Controller&#xa;→ Ingress rule (Host) → ClusterIP Service&#xa;→ Endpoints → Pod :3000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFCCB;strokeColor=#65A30D;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="k_edge">
          <mxGeometry x="1000" y="30" width="400" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="k_ns_box" value="Namespace: k8s-demo-namespace&#xa;labels: app=hello-demo&#xa;environment=learning&#xa;Secret: ghcr-secret (imagePull)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#DB2777;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="k_edge">
          <mxGeometry x="1420" y="30" width="300" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="k_ing_ns" value="Namespace: ingress-nginx&#xa;controller Deployment&#xa;Admission webhook svc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0E7FF;strokeColor=#4F46E5;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="k_edge">
