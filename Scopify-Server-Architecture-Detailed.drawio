        <mxCell id="k8s_note" value="Kubernetes fabric (across nodes): kubeadm 1.35.6 · Calico v3.32.1 (Pod CIDR 10.244.0.0/16) · Ingress-Nginx controller-v1.15.1 (NodePort) — pods on Master/Worker-1/Worker-2 all share this overlay network regardless of subnet/AZ." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFCCB;strokeColor=#65A30D;fontSize=11;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="vpc">
          <mxGeometry x="740" y="790" width="990" height="80" as="geometry"/>
