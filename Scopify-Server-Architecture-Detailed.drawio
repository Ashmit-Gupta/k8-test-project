        <!-- Admin access box (inside VPC, spans conceptually) -->
        <mxCell id="admin_box" value="ADMIN ACCESS PATHS&#xa;1) SSM Session Manager → any private EC2&#xa;    (via ssm/ssmmessages/ec2messages endpoints)&#xa;2) SSH -J ubuntu@NginxEIP ubuntu@&lt;private-ip&gt;&#xa;    (ProxyJump through Nginx)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#7C3AED;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="vpc">
